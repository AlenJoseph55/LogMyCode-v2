{
  "name": "vscode-extension",
  "displayName": "LogMyCode",
  "description": "Log My Code v2: Hybrid graph-vector memory logger integrated with Cognee.",
  "version": "2.0.0",
  "publisher": "logmycode",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "logmycode.showDashboard",
        "title": "LogMyCode: Show Dashboard"
      }
    ],
    "configuration": {
      "title": "LogMyCode",
      "properties": {
        "logmycode.backendUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the LogMyCode backend service."
        },
        "logmycode.llmApiKey": {
          "type": "string",
          "default": "",
          "description": "Your custom LLM API Key (e.g. Groq API Key) for SCPP and daily summaries (Free Tier)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.1",
    "typescript": "^5.3.3"
  }
}
